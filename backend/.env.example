# Copy to .env and adjust. Nothing here needs to be correct for `pytest` to
# pass — the full test suite runs against FakeLLMClient. These only matter
# once you point LLM_BACKEND at "ollama" for a real functional-acceptance run.

LLM_BACKEND=fake
OLLAMA_HOST=http://<other-laptop-lan-ip>:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

DATABASE_URL=sqlite+aiosqlite:///./inspiron.db

GRAPH_STORE_BACKEND=fake
VECTOR_STORE_BACKEND=fake
OBJECT_STORE_BACKEND=local
OBJECT_STORE_DIR=./data/objects

REDIS_URL=redis://localhost:6379/0

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=inspiron_dev
